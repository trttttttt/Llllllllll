}

function equipArtifact(artifactKey) {
    if (gameState.equippedArtifacts.length >= 3) {
        showAchievement('❌ Max 3 artifacts!');
        return;
    }
    
    gameState.equippedArtifacts.push(artifactKey);
    renderArtifacts();
    showAchievement(`✨ Equipped ${GAME_DATA.recipes[artifactKey].n}!`);
}

function unequipArtifact(slotIndex) {
    const artifactKey = gameState.equippedArtifacts[slotIndex];
    gameState.equippedArtifacts.splice(slotIndex, 1);
    renderArtifacts();
    showAchievement(`Unequipped ${GAME_DATA.recipes[artifactKey].n}!`);
}

function getArtifactBonus(bonusType) {
    let total = 0;
    
    gameState.equippedArtifacts.forEach(artifactKey => {
        const artifact = GAME_DATA.recipes[artifactKey];
        if (artifact && artifact.b) {
            if (artifact.b.t === bonusType || artifact.b.t === 'all_bonus') {
                total += artifact.b.v;
            }
        }
    });
    
    return total;
}

function renderShop() {
    const container = document.getElementById('shopGrid');
    container.innerHTML = '';
    
    Object.keys(GAME_DATA.shop).forEach(itemKey => {
        const item = GAME_DATA.shop[itemKey];
        const currentLevel = gameState.shopUpgrades[itemKey] || 0;
        const maxed = currentLevel >= item.m;
        const cost = item.c * (currentLevel + 1);
        
        const shopCard = document.createElement('div');
        shopCard.className = 'shop-item';
        shopCard.innerHTML = `
            <div style="text-align: center;">
                <div style="font-size: 48px; margin-bottom: 10px;">${item.e}</div>
                <h3>${item.n}</h3>
                <p style="font-size: 14px; opacity: 0.8; margin: 10px 0;">${item.d}</p>
                <div style="font-size: 12px; color: #ffd700; margin: 10px 0;">
                    Level: ${currentLevel}/${item.m}
                </div>
                <div class="shop-price">⚫ ${cost} Dark Essence</div>
                <button class="buy-btn" onclick="buyShopItem('${itemKey}')" ${maxed || gameState.darkEssence < cost ? 'disabled' : ''}>
                    ${maxed ? 'MAX LEVEL' : 'BUY'}
                </button>
            </div>
        `;
        
        container.appendChild(shopCard);
    });
}

function buyShopItem(itemKey) {
    const item = GAME_DATA.shop[itemKey];
    const currentLevel = gameState.shopUpgrades[itemKey] || 0;
    const cost = item.c * (currentLevel + 1);
    
    if (currentLevel >= item.m) {
        showAchievement('Already at max level!');
        return;
    }
    
    if (gameState.darkEssence < cost) {
        showAchievement('Not enough Dark Essence!');
        return;
    }
    
    gameState.darkEssence -= cost;
    gameState.shopUpgrades[itemKey] = currentLevel + 1;
    
    showAchievement(`✨ Purchased ${item.n} Lv${currentLevel + 1}!`);
    renderShop();
    updateUI();
}

function getShopBonus(bonusType) {
    let total = 0;
    
    Object.keys(gameState.shopUpgrades).forEach(itemKey => {
        const item = GAME_DATA.shop[itemKey];
        const level = gameState.shopUpgrades[itemKey];
        
        if (item && item.b && item.b.t === bonusType) {
            total += item.b.v * level;
        }
    });
    
    return total;
}

function upgradeMonster(type) {
    const m = GAME_DATA.monsters[type];
    const cost = m.c * Math.pow(1.15, m.lv);
    
    if (gameState.gold >= cost) {
        gameState.gold -= cost;
        m.lv++;
        renderMonsterCards();
        updateUI();
    }
}

function upgradeHero(type) {
    const h = GAME_DATA.heroes[type];
    const cost = h.c * Math.pow(1.15, h.lv);
    
    if (gameState.gold >= cost) {
        gameState.gold -= cost;
        h.lv++;
        renderHeroCards();
        updateUI();
    }
}

function autoUpgradeLogic() {
    let bestUpgrade = null;
    let bestRatio = 0;

    Object.keys(GAME_DATA.monsters).forEach(key => {
        const m = GAME_DATA.monsters[key];
        const cost = m.c * Math.pow(1.15, m.lv);
        const value = m.sr * m.dr;
        const ratio = value / cost;
        
        if (gameState.gold >= cost && ratio > bestRatio) {
            bestRatio = ratio;
            bestUpgrade = { type: 'monster', key: key };
        }
    });

    Object.keys(GAME_DATA.heroes).forEach(key => {
        const h = GAME_DATA.heroes[key];
        const cost = h.c * Math.pow(1.15, h.lv);
        const value = h.p * h.ar;
        const ratio = value / cost;
        
        if (gameState.gold >= cost && ratio > bestRatio) {
            bestRatio = ratio;
            bestUpgrade = { type: 'hero', key: key };
        }
    });

    if (bestUpgrade) {
        if (bestUpgrade.type === 'monster') {
            upgradeMonster(bestUpgrade.key);
        } else {
            upgradeHero(bestUpgrade.key);
        }
    }
}

function calculateEssenceGain() {
    const baseEssence = Math.floor(Math.sqrt(gameState.totalGoldEarned / 1000));
    const bonus = 1 + (getShopBonus('prestige_bonus') / 100);
    return Math.floor(baseEssence * bonus);
}

function getMultiplier(essence = null) {
    const de = essence !== null ? essence : gameState.darkEssence;
    return 1 + (de * 0.1);
}

function doPrestige() {
    const essenceGain = calculateEssenceGain();
    
    if (essenceGain === 0) {
        alert('Need more gold before prestiging!');
        return;
    }
    
    if (!confirm(`Gain ${essenceGain} Dark Essence and reset?`)) {
        return;
    }
    
    const keptArtifacts = [...gameState.ownedArtifacts];
    const keptEquipped = [...gameState.equippedArtifacts];
    const keptShop = {...gameState.shopUpgrades};
    const keptWorlds = [...gameState.unlockedWorlds];
    
    gameState.darkEssence += essenceGain;
    gameState.prestigeCount++;
    
    gameState.gold = 0;
    gameState.currentFloor = 1;
    gameState.currentWorld = 1;
    gameState.floorProgress = 0;
    gameState.totalGoldEarned = 0;
    gameState.monstersKilled = 0;
    gameState.activeMonsters = [];
    gameState.activeHeroes = [];
    gameState.bossActive = false;
    gameState.inventory = {};
    gameState.unlockedFloors = [1];
    gameState.farmMode = false;
    
    Object.keys(GAME_DATA.monsters).forEach(key => {
        GAME_DATA.monsters[key].lv = key === 'bat' ? 1 : 0;
    });
    Object.keys(GAME_DATA.heroes).forEach(key => {
        GAME_DATA.heroes[key].lv = key === 'warrior' ? 1 : 0;
    });
    
    gameState.ownedArtifacts = keptArtifacts;
    gameState.equippedArtifacts = keptEquipped;
    gameState.shopUpgrades = keptShop;
    gameState.unlockedWorlds = keptWorlds;
    
    showEventBanner('🔄 PRESTIGE!', `+${essenceGain} Dark Essence! ${getMultiplier().toFixed(1)}x`);
    
    renderMonsterCards();
    renderHeroCards();
    renderFloorGrid();
    renderWorldSelector();
    renderInventory();
    renderArtifacts();
    renderShop();
    updateUI();
}

