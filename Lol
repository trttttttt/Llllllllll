            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 10px;">
                <span style="font-size: 32px;">${recipe.e}</span>
                <strong style="font-size: 14px;">${recipe.n}</strong>
            </div>
            <div style="font-size: 12px;">${matsHTML}</div>
