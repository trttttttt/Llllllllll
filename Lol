<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>🏰 Idle Dungeon Master - Complete</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            color: #fff;
            overflow-x: hidden;
        }
        
        .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
        
        .header {
            background: rgba(0, 0, 0, 0.5);
            border-radius: 15px;
            padding: 20px;
            margin-bottom: 20px;
            border: 2px solid #ffd700;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.3);
        }
        
        .main-stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .stat-box {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
        }
        
        .stat-label { font-size: 12px; opacity: 0.8; margin-bottom: 5px; }
        .stat-value { font-size: 24px; font-weight: bold; text-shadow: 0 0 10px rgba(255, 255, 255, 0.5); }
        
        .floor-info {
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            font-size: 20px;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
        }
        
        .farm-mode-toggle {
            background: #38ef7d;
            padding: 10px 20px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            border: 2px solid #fff;
            transition: all 0.3s;
        }
        
        .farm-mode-toggle:hover { transform: scale(1.05); }
        .farm-mode-toggle.active { 
            background: #ff6b6b; 
            animation: pulse 1.5s infinite; 
        }
        
        @keyframes pulse {
            0%, 100% { box-shadow: 0 0 0 0 rgba(255, 107, 107, 0.7); }
            50% { box-shadow: 0 0 0 10px rgba(255, 107, 107, 0); }
        }
        
        .tabs {
            display: flex;
            gap: 10px;
            margin-bottom: 20px;
            flex-wrap: wrap;
        }
        
        .tab-btn {
            flex: 1;
            min-width: 120px;
            padding: 12px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            color: #fff;
            font-size: 14px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .tab-btn:hover { background: rgba(255, 255, 255, 0.2); transform: translateY(-2px); }
        .tab-btn.active {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-color: #ffd700;
            box-shadow: 0 0 20px rgba(102, 126, 234, 0.5);
        }
        
        .content-section { display: none; }
        .content-section.active { display: block; }
        
        .card-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 15px;
        }
        
        .card {
            background: rgba(0, 0, 0, 0.4);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 15px;
            padding: 20px;
            transition: all 0.3s;
        }
        
        .card:hover {
            transform: translateY(-5px);
            border-color: #ffd700;
            box-shadow: 0 10px 30px rgba(255, 215, 0, 0.3);
        }
        
        .card-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 15px;
        }
        
        .card-icon { font-size: 40px; margin-right: 10px; }
        .card-title { flex: 1; font-size: 18px; font-weight: bold; }
        .card-level {
            background: #ffd700;
            color: #000;
            padding: 5px 10px;
            border-radius: 20px;
            font-weight: bold;
            font-size: 14px;
        }
        
        .card-stats { margin: 15px 0; font-size: 14px; }
        .card-stat {
            display: flex;
            justify-content: space-between;
            margin: 8px 0;
            padding: 5px 0;
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        }
        
        .upgrade-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 10px;
        }
        
        .upgrade-btn:hover:not(:disabled) {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(56, 239, 125, 0.4);
        }
        
        .upgrade-btn:disabled { background: #666; cursor: not-allowed; }
        
        .dungeon-view {
            background: rgba(0, 0, 0, 0.6);
            border: 3px solid #ffd700;
            border-radius: 15px;
            padding: 20px;
            min-height: 400px;
            position: relative;
            overflow: hidden;
            margin-bottom: 20px;
        }
        
        .dungeon-entities {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            justify-content: center;
            align-items: center;
            min-height: 350px;
        }
        
        .entity {
            font-size: 40px;
            position: relative;
            cursor: pointer;
            transition: transform 0.2s;
        }
        
        .entity:hover { transform: scale(1.2); }
        .entity.monster { animation: float 3s ease-in-out infinite; }
        .entity.hero { animation: bounce 2s ease-in-out infinite; }
        .entity.boss {
            font-size: 60px;
            animation: bossPulse 2s ease-in-out infinite;
            filter: drop-shadow(0 0 10px rgba(255, 0, 0, 0.8));
        }
        
        @keyframes float {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
        }
        
        @keyframes bounce {
            0%, 100% { transform: translateY(0px); }
            50% { transform: translateY(-15px); }
        }
        
        @keyframes bossPulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.1); filter: drop-shadow(0 0 20px rgba(255, 0, 0, 1)); }
        }
        
        .boss-health {
            background: rgba(0, 0, 0, 0.8);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 15px;
        }
        
        .boss-name {
            font-size: 24px;
            font-weight: bold;
            color: #ff4444;
            margin-bottom: 10px;
            text-align: center;
            text-shadow: 0 0 10px rgba(255, 68, 68, 0.8);
        }
        
        .boss-hp-bar {
            background: rgba(255, 255, 255, 0.2);
            height: 40px;
            border-radius: 20px;
            overflow: hidden;
        }
        
        .boss-hp-fill {
            background: linear-gradient(90deg, #ff0000 0%, #ff4444 100%);
            height: 100%;
            border-radius: 20px;
            transition: width 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 16px;
        }
        
        .floor-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 10px;
        }
        
        .floor-box {
            background: rgba(0, 0, 0, 0.5);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .floor-box:hover:not(.locked) {
            transform: translateY(-5px);
            border-color: #ffd700;
            box-shadow: 0 5px 20px rgba(255, 215, 0, 0.3);
        }
        
        .floor-box.locked { opacity: 0.5; cursor: not-allowed; }
        .floor-box.current {
            border-color: #38ef7d;
            box-shadow: 0 0 20px rgba(56, 239, 125, 0.5);
        }
        .floor-box.boss-floor {
            border-color: #ff4444;
            background: linear-gradient(135deg, rgba(255, 0, 0, 0.2) 0%, rgba(139, 0, 0, 0.2) 100%);
        }
        
        .inventory-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 10px;
        }
        
        .inventory-item {
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 10px;
            padding: 15px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s;
            position: relative;
        }
        
        .inventory-item:hover {
            transform: scale(1.05);
            border-color: #ffd700;
        }
        
        .item-icon { font-size: 40px; margin-bottom: 5px; }
        .item-count {
            position: absolute;
            top: 5px;
            right: 5px;
            background: #ffd700;
            color: #000;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: bold;
        }
        
        .item-rarity-common { border-color: #9e9e9e; }
        .item-rarity-uncommon { border-color: #4caf50; }
        .item-rarity-rare { border-color: #2196f3; }
        .item-rarity-epic { border-color: #9c27b0; }
        .item-rarity-legendary { border-color: #ff9800; }
        .item-rarity-mythic { border-color: #e91e63; }
        
        .crafting-section {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }
        
        .recipe-list {
            background: rgba(0, 0, 0, 0.4);
            border-radius: 15px;
            padding: 20px;
            max-height: 600px;
            overflow-y: auto;
        }
        
        .recipe-card {
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.2);
            border-radius: 10px;
            padding: 15px;
            margin-bottom: 15px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .recipe-card:hover {
            border-color: #ffd700;
            transform: translateX(5px);
        }
        
        .recipe-card.selected {
            border-color: #38ef7d;
            background: rgba(56, 239, 125, 0.2);
        }
        
        .craft-btn {
            width: 100%;
            padding: 15px;
            background: linear-gradient(135deg, #ff6b6b 0%, #ee5a6f 100%);
            border: none;
            border-radius: 10px;
            color: #fff;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 15px;
        }
        
        .craft-btn:hover:not(:disabled) {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(255, 107, 107, 0.5);
        }
        
        .craft-btn:disabled { background: #666; cursor: not-allowed; }
        
        .artifact-slot {
            background: rgba(0, 0, 0, 0.6);
            border: 3px solid rgba(255, 215, 0, 0.5);
            border-radius: 15px;
            padding: 20px;
            text-align: center;
            min-height: 150px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: all 0.3s;
        }
        
        .artifact-slot:hover {
            border-color: #ffd700;
            box-shadow: 0 0 30px rgba(255, 215, 0, 0.3);
        }
        
        .artifact-slot.equipped {
            background: linear-gradient(135deg, rgba(255, 215, 0, 0.2) 0%, rgba(255, 140, 0, 0.2) 100%);
        }
        
        .artifact-bonus {
            font-size: 14px;
            color: #38ef7d;
            margin-top: 10px;
        }
        
        .shop-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .shop-item {
            background: rgba(0, 0, 0, 0.6);
            border: 2px solid #9c27b0;
            border-radius: 15px;
            padding: 20px;
            transition: all 0.3s;
        }
        
        .shop-item:hover {
            transform: translateY(-5px);
            border-color: #ffd700;
            box-shadow: 0 10px 30px rgba(156, 39, 176, 0.5);
        }
        
        .shop-price {
            background: linear-gradient(135deg, #9c27b0 0%, #673ab7 100%);
            padding: 10px;
            border-radius: 8px;
            margin: 10px 0;
            font-size: 18px;
            font-weight: bold;
        }
        
        .buy-btn {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #9c27b0 0%, #673ab7 100%);
            border: none;
            border-radius: 8px;
            color: #fff;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .buy-btn:hover:not(:disabled) {
            transform: scale(1.05);
            box-shadow: 0 5px 20px rgba(156, 39, 176, 0.5);
        }
        
        .buy-btn:disabled { background: #666; cursor: not-allowed; }
        
        .loot-particle {
            position: absolute;
            font-size: 20px;
            animation: lootFloat 2s ease-out forwards;
            pointer-events: none;
            z-index: 100;
        }
        
        @keyframes lootFloat {
            0% { transform: translateY(0) scale(1); opacity: 1; }
            100% { transform: translateY(-100px) scale(0.5); opacity: 0; }
        }
        
        .prestige-section {
            background: linear-gradient(135deg, #ff0844 0%, #ffb199 100%);
            border-radius: 15px;
            padding: 30px;
            text-align: center;
        }
        
        .prestige-btn {
            padding: 20px 40px;
            background: linear-gradient(135deg, #ffd700 0%, #ff8c00 100%);
            border: 3px solid #fff;
            border-radius: 15px;
            color: #000;
            font-size: 24px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
        }
        
        .prestige-btn:hover:not(:disabled) {
            transform: scale(1.1) rotateZ(2deg);
            box-shadow: 0 15px 40px rgba(255, 215, 0, 0.6);
        }
        
        .prestige-btn:disabled { background: #666; cursor: not-allowed; opacity: 0.5; }
        
        .event-banner {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0);
            background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            padding: 40px 60px;
            border-radius: 20px;
            border: 5px solid #ffd700;
            z-index: 1000;
            text-align: center;
            box-shadow: 0 0 50px rgba(0, 0, 0, 0.8);
            animation: eventPop 0.5s ease-out forwards;
        }
        
        @keyframes eventPop {
            0% { transform: translate(-50%, -50%) scale(0); }
            50% { transform: translate(-50%, -50%) scale(1.1); }
            100% { transform: translate(-50%, -50%) scale(1); }
        }
        
        .event-banner h2 {
            font-size: 36px;
            margin-bottom: 10px;
            text-shadow: 0 0 20px rgba(255, 255, 255, 0.8);
        }
        
        .achievement-popup {
            position: fixed;
            top: 20px;
            right: 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px 30px;
            border-radius: 15px;
            border: 2px solid #ffd700;
            z-index: 999;
            animation: slideIn 0.5s ease-out;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }
        
        @keyframes slideIn {
            from { transform: translateX(400px); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }
        
        .floor-progress { margin-top: 15px; }
        .progress-bar {
            background: rgba(255, 255, 255, 0.2);
            height: 30px;
            border-radius: 15px;
            overflow: hidden;
        }
        
        .progress-fill {
            background: linear-gradient(90deg, #11998e 0%, #38ef7d 100%);
            height: 100%;
            border-radius: 15px;
            transition: width 0.5s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 14px;
        }
        
        .auto-features {
            background: rgba(0, 0, 0, 0.4);
            padding: 20px;
            border-radius: 15px;
            margin-bottom: 20px;
        }
        
        .auto-toggle {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 10px 0;
            padding: 10px;
            background: rgba(255, 255, 255, 0.1);
            border-radius: 8px;
        }
        
        .toggle-switch {
            width: 60px;
            height: 30px;
            background: #666;
            border-radius: 15px;
            position: relative;
            cursor: pointer;
            transition: background 0.3s;
        }
        
        .toggle-switch.active { background: #38ef7d; }
        .toggle-switch::after {
            content: '';
            position: absolute;
            width: 26px;
            height: 26px;
            background: #fff;
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: left 0.3s;
        }
        
        .toggle-switch.active::after { left: 32px; }
        
        @media (max-width: 768px) {
            .main-stats { grid-template-columns: 1fr 1fr; }
            .card-grid { grid-template-columns: 1fr; }
            .tabs { flex-direction: column; }
            .crafting-section { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <div class="main-stats">
                <div class="stat-box">
                    <div class="stat-label">💰 Gold/Second</div>
                    <div class="stat-value" id="goldPerSec">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">💎 Total Gold</div>
                    <div class="stat-value" id="totalGold">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">👾 Monsters Killed</div>
                    <div class="stat-value" id="monstersKilled">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">⚫ Dark Essence</div>
                    <div class="stat-value" id="darkEssence">0</div>
                </div>
                <div class="stat-box">
                    <div class="stat-label">🎒 Items</div>
                    <div class="stat-value" id="totalItems">0</div>
                </div>
            </div>
            <div class="floor-info">
                <div>
                    🏰 Floor <span id="currentFloor">1</span>/100 - <span id="biomeName">DARK CAVES</span>
                </div>
                <div class="farm-mode-toggle" id="farmModeBtn" onclick="toggleFarmMode()">
                    🌾 Farm Mode: OFF
                </div>
            </div>
            <div class="floor-progress">
                <div class="progress-bar">
                    <div class="progress-fill" id="floorProgress" style="width: 0%">0%</div>
                </div>
            </div>
        </div>

        <div class="auto-features">
            <h3>🤖 Auto Features</h3>
            <div class="auto-toggle">
                <span>Auto-Collect Loot</span>
                <div class="toggle-switch active" id="autoCollectToggle" onclick="toggleAuto('collect')"></div>
            </div>
            <div class="auto-toggle">
                <span>Auto-Upgrade (Floor 10+)</span>
                <div class="toggle-switch" id="autoUpgradeToggle" onclick="toggleAuto('upgrade')"></div>
            </div>
            <div class="auto-toggle">
                <span>Auto-Prestige (Prestige 1+)</span>
                <div class="toggle-switch" id="autoPrestigeToggle" onclick="toggleAuto('prestige')"></div>
            </div>
        </div>

        <div class="tabs">
            <button class="tab-btn active" onclick="switchTab('dungeon', event)">🏰 Dungeon</button>
            <button class="tab-btn" onclick="switchTab('monsters', event)">👾 Monsters</button>
            <button class="tab-btn" onclick="switchTab('heroes', event)">⚔️ Heroes</button>
            <button class="tab-btn" onclick="switchTab('floors', event)">🗺️ Floors</button>
            <button class="tab-btn" onclick="switchTab('inventory', event)">🎒 Inventory</button>
            <button class="tab-btn" onclick="switchTab('crafting', event)">⚒️ Crafting</button>
            <button class="tab-btn" onclick="switchTab('artifacts', event)">✨ Artifacts</button>
            <button class="tab-btn" onclick="switchTab('shop', event)">🛒 Shop</button>
            <button class="tab-btn" onclick="switchTab('prestige', event)">🔄 Prestige</button>
        </div>

        <div id="dungeon" class="content-section active">
            <div id="bossHealthContainer"></div>
            <div class="dungeon-view">
                <div class="dungeon-entities" id="dungeonEntities"></div>
            </div>
        </div>

        <div id="monsters" class="content-section">
            <div class="card-grid" id="monsterCards"></div>
        </div>

        <div id="heroes" class="content-section">
            <div class="card-grid" id="heroCards"></div>
        </div>

        <div id="floors" class="content-section">
            <h2 style="margin-bottom: 20px;">🗺️ Select Floor (Red = Boss Floor)</h2>
            <div class="floor-grid" id="floorGrid"></div>
        </div>

        <div id="inventory" class="content-section">
            <h2 style="margin-bottom: 20px;">🎒 Item Inventory</h2>
            <div class="inventory-grid" id="inventoryGrid"></div>
        </div>

        <div id="crafting" class="content-section">
            <h2 style="margin-bottom: 20px;">⚒️ Crafting Station</h2>
            <div class="crafting-section">
                <div class="recipe-list" id="recipeList"></div>
                <div class="recipe-list">
                    <h3>Selected Recipe</h3>
                    <div id="selectedRecipe" style="margin-top: 20px; font-size: 14px;">
                        Select a recipe from the left
                    </div>
                    <button class="craft-btn" id="craftBtn" onclick="craftItem()" disabled>
                        ⚒️ CRAFT
                    </button>
                </div>
            </div>
        </div>

        <div id="artifacts" class="content-section">
            <h2 style="margin-bottom: 20px;">✨ Artifacts (Equip up to 3)</h2>
            <div class="card-grid" id="artifactSlots"></div>
            <h3 style="margin-top: 30px; margin-bottom: 15px;">Available Artifacts</h3>
            <div class="card-grid" id="availableArtifacts"></div>
        </div>

        <div id="shop" class="content-section">
            <h2 style="margin-bottom: 20px;">🛒 Dark Essence Shop</h2>
            <div class="shop-grid" id="shopGrid"></div>
        </div>

        <div id="prestige" class="content-section">
            <div class="prestige-section">
                <h2>🔄 DUNGEON COLLAPSE</h2>
                <p style="font-size: 18px; margin: 20px 0;">Reset your dungeon and gain permanent power!</p>
                
