            const itemDiv = document.createElement('div');
            itemDiv.className = `inventory-item item-rarity-${item.r}`;
            itemDiv.innerHTML = `
                <div class="item-icon">${item.e}</div>
                <div style="font-size: 12px;">${item.n}</div>
                <div class="item-count">${count}</div>
            `;
            
            container.appendChild(itemDiv);
        }
    });
}

function renderCraftingRecipes() {
    const container = document.getElementById('recipeList');
    container.innerHTML = '<h3>Available Recipes</h3>';
    
    Object.keys(GAME_DATA.recipes).forEach(recipeKey => {
        const recipe = GAME_DATA.recipes[recipeKey];
        
        const card = document.createElement('div');
        card.className = 'recipe-card';
        card.setAttribute('data-recipe', recipeKey);
        card.onclick = function(e) {
