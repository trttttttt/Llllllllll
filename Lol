            matsHTML += `
                <div style="color: ${hasEnough ? '#38ef7d' : '#ff6b6b'}; font-size: 11px;">
                    ${GAME_DATA.items[matKey].e} ${GAME_DATA.items[matKey].n}: ${owned}/${needed}
                </div>
            `;
