function startGameLoop() {
    setInterval(() => {
        const now = Date.now();
        const deltaTime = (now - gameState.lastUpdate) / 1000;
        gameState.lastUpdate = now;

        // PASSIVE GOLD GENERATION - NEW FIX
        generatePassiveGold(deltaTime);

        if (!gameState.bossActive && isBossFloor(gameState.currentFloor)) {
            if (gameState.floorProgress >= getRequiredKills()) {
                spawnBoss();
            }
        }

        if (!gameState.bossActive) {
            spawnMonsters(deltaTime);
        }
        
        heroesAttack(deltaTime);
        updateUI();
        
        if (gameState.autoUpgrade && gameState.currentFloor >= 10) {
            autoUpgradeLogic();
        }
        
        if (gameState.autoPrestige && gameState.prestigeCount >= 1) {
            const essenceGain = calculateEssenceGain();
            const currentMult = getMultiplier();
            const afterMult = getMultiplier(gameState.darkEssence + essenceGain);
            if (essenceGain > 0 && afterMult >= currentMult * 2) {
                doPrestige();
            }
        }
    }, 100);

    setInterval(() => renderDungeon(), 50);
    setInterval(() => saveGame(), 5000);
}

// NEW: Passive gold generation function
function generatePassiveGold(deltaTime) {
    let goldPerSecond = 0;
    
    // Calculate gold from active heroes attacking
    gameState.activeHeroes.forEach(hero => {
        goldPerSecond += hero.power * hero.attackRate * 0.5;
    });
    
    // Calculate gold from all upgraded heroes (even if not spawned yet)
    Object.keys(GAME_DATA.heroes).forEach(key => {
        const h = GAME_DATA.heroes[key];
        if (h.lv > 0) {
            const heroPower = h.p * h.lv * (1 + (getArtifactBonus('hero_power') + getShopBonus('hero_power')) / 100);
            goldPerSecond += heroPower * h.ar * 0.1; // Base passive income
        }
    });
    
    // Apply multipliers
    goldPerSecond *= getMultiplier();
    
    // Add gold based on delta time
    const goldToAdd = goldPerSecond * deltaTime;
    if (goldToAdd > 0) {
        gameState.gold += goldToAdd;
        gameState.totalGoldEarned += goldToAdd;
    }
}

function isBossFloor(floor) {
    return floor % 10 === 0;
}

function spawnBoss() {
    const worldBiomes = getBiomesForCurrentWorld();
    const biomeIndex = Math.floor((gameState.currentFloor - 1) / 10) % worldBiomes.length;
    const biome = worldBiomes[biomeIndex];
    
    gameState.bossActive = true;
    gameState.bossMaxHP = 1000 * gameState.currentFloor * (1 + gameState.currentFloor * 0.5);
    gameState.bossHP = gameState.bossMaxHP;
    gameState.bossName = biome ? biome.b : '👹 Boss Monster';
    showEventBanner('⚔️ BOSS APPEARED!', gameState.bossName);
}

function getBiomesForCurrentWorld() {
    const worldId = Math.ceil(gameState.currentFloor / 100);
    const baseIndex = (worldId - 1) * 10;
    
    return [
        {f:[1,10], n:`World ${worldId} - Zone 1`, b:'🦇 Bat King'},
