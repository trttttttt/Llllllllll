        entity.className = 'entity monster';
        entity.innerHTML = monster.emoji;
        entity.style.animationDelay = `${i * 0.1}s`;
        container.appendChild(entity);
    });
    
    gameState.activeHeroes.slice(0, 15).forEach((hero, i) => {
        const entity = document.createElement('div');
        entity.className = 'entity hero';
        entity.innerHTML = hero.emoji;
        entity.style.animationDelay = `${i * 0.15}s`;
        container.appendChild(entity);
    });
}

function createLootParticle() {
    const container = document.getElementById('dungeonEntities');
    const particle = document.createElement('div');
    particle.className = 'loot-particle';
    particle.innerHTML = '💰';
    particle.style.left = Math.random() * 90 + '%';
    particle.style.top = Math.random() * 90 + '%';
    container.appendChild(particle);
    
    setTimeout(() => particle.remove(), 2000);
}

function updateUI() {
    // Calculate REAL gold per second with passive income
    let goldPerSec = 0;
    
    // Active heroes attacking
    gameState.activeHeroes.forEach(hero => {
        goldPerSec += hero.power * hero.attackRate * 0.5;
    });
    
    // Passive income from all upgraded heroes
    Object.keys(GAME_DATA.heroes).forEach(key => {
        const h = GAME_DATA.heroes[key];
        if (h.lv > 0) {
            const heroPower = h.p * h.lv * (1 + (getArtifactBonus('hero_power') + getShopBonus('hero_power')) / 100);
            goldPerSec += heroPower * h.ar * 0.1;
        }
    });
    
    goldPerSec *= getMultiplier();
    
    document.getElementById('goldPerSec').textContent = formatNumber(goldPerSec);
    document.getElementById('totalGold').textContent = formatNumber(gameState.gold);
    document.getElementById('monstersKilled').textContent = formatNumber(gameState.monstersKilled);
    document.getElementById('darkEssence').textContent = formatNumber(gameState.darkEssence);
    
    let totalItems = 0;
    Object.values(gameState.inventory).forEach(count => totalItems += count);
    document.getElementById('totalItems').textContent = formatNumber(totalItems);
    
    document.getElementById('currentFloor').textContent = gameState.currentFloor;
    
    const worldBiomes = getBiomesForCurrentWorld();
    const localFloor = ((gameState.currentFloor - 1) % 100) + 1;
    const biomeIndex = Math.floor((localFloor - 1) / 10);
    const biome = worldBiomes[biomeIndex];
    if (biome) document.getElementById('biomeName').textContent = biome.n;
    
    const requiredKills = getRequiredKills();
    const progressPercent = Math.min((gameState.floorProgress / requiredKills) * 100, 100);
    document.getElementById('floorProgress').style.width = progressPercent + '%';
    document.getElementById('floorProgress').textContent = Math.floor(progressPercent) + '%';
    
    const essenceGain = calculateEssenceGain();
    const currentMult = getMultiplier();
    const afterMult = getMultiplier(gameState.darkEssence + essenceGain);
    
    document.getElementById('essenceGain').textContent = formatNumber(essenceGain);
    document.getElementById('currentMultiplier').textContent = currentMult.toFixed(1) + 'x';
    document.getElementById('afterMultiplier').textContent = afterMult.toFixed(1) + 'x';
    
    document.getElementById('prestigeBtn').disabled = essenceGain === 0;
}

function formatNumber(num) {
    if (num >= 1e12) return (num / 1e12).toFixed(2) + 'T';
    if (num >= 1e9) return (num / 1e9).toFixed(2) + 'B';
    if (num >= 1e6) return (num / 1e6).toFixed(2) + 'M';
    if (num >= 1e3) return (num / 1e3).toFixed(2) + 'K';
    return Math.floor(num).toString();
}

function switchTab(tabName, event) {
    document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
    document.querySelectorAll('.content-section').forEach(section => section.classList.remove('active'));
    
    event.target.classList.add('active');
    document.getElementById(tabName).classList.add('active');
    
    if (tabName === 'inventory') renderInventory();
    if (tabName === 'artifacts') renderArtifacts();
    if (tabName === 'shop') renderShop();
    if (tabName === 'floors') {
        renderWorldSelector();
        renderFloorGrid();
    }
}

function toggleAuto(feature) {
    if (feature === 'collect') {
        gameState.autoCollect = !gameState.autoCollect;
        document.getElementById('autoCollectToggle').classList.toggle('active');
    } else if (feature === 'upgrade') {
        if (gameState.currentFloor >= 10) {
            gameState.autoUpgrade = !gameState.autoUpgrade;
            document.getElementById('autoUpgradeToggle').classList.toggle('active');
        } else {
            alert('Unlock at Floor 10!');
        }
    } else if (feature === 'prestige') {
        if (gameState.prestigeCount >= 1) {
            gameState.autoPrestige = !gameState.autoPrestige;
            document.getElementById('autoPrestigeToggle').classList.toggle('active');
        } else {
            alert('Unlock after first prestige!');
        }
    }
}

function showAchievement(message) {
    const popup = document.createElement('div');
    popup.className = 'achievement-popup';
    popup.innerHTML = `<h3>🏆 Achievement</h3><p>${message}</p>`;
    document.body.appendChild(popup);
    setTimeout(() => popup.remove(), 3000);
}

function showEventBanner(title, message) {
    const banner = document.createElement('div');
    banner.className = 'event-banner';
    banner.innerHTML = `<h2>${title}</h2><p style="font-size: 20px; margin-top: 10px;">${message}</p>`;
    document.body.appendChild(banner);
    setTimeout(() => banner.remove(), 3000);
}

function saveGame() {
    const saveData = {
        gold: gameState.gold,
        darkEssence: gameState.darkEssence,
        monstersKilled: gameState.monstersKilled,
        currentFloor: gameState.currentFloor,
        currentWorld: gameState.currentWorld,
        floorProgress: gameState.floorProgress,
        prestigeCount: gameState.prestigeCount,
        totalGoldEarned: gameState.totalGoldEarned,
        farmMode: gameState.farmMode,
        unlockedFloors: gameState.unlockedFloors,
        unlockedWorlds: gameState.unlockedWorlds,
        autoCollect: gameState.autoCollect,
        autoUpgrade: gameState.autoUpgrade,
        autoPrestige: gameState.autoPrestige,
        inventory: gameState.inventory,
        equippedArtifacts: gameState.equippedArtifacts,
        ownedArtifacts: gameState.ownedArtifacts,
        shopUpgrades: gameState.shopUpgrades,
        lastUpdate: gameState.lastUpdate,
        monsters: {},
        heroes: {}
    };
    
    Object.keys(GAME_DATA.monsters).forEach(key => {
        saveData.monsters[key] = GAME_DATA.monsters[key].lv;
    });
    
    Object.keys(GAME_DATA.heroes).forEach(key => {
        saveData.heroes[key] = GAME_DATA.heroes[key].lv;
    });
    
    localStorage.setItem('idleDungeonComplete', JSON.stringify(saveData));
}

function loadGame() {
    const saved = localStorage.getItem('idleDungeonComplete');
    if (saved) {
        const loaded = JSON.parse(saved);
        
        gameState.gold = loaded.gold || 0;
        gameState.darkEssence = loaded.darkEssence || 0;
        gameState.monstersKilled = loaded.monstersKilled || 0;
        gameState.currentFloor = loaded.currentFloor || 1;
        gameState.currentWorld = loaded.currentWorld || 1;
        gameState.floorProgress = loaded.floorProgress || 0;
        gameState.prestigeCount = loaded.prestigeCount || 0;
        gameState.totalGoldEarned = loaded.totalGoldEarned || 0;
        gameState.farmMode = loaded.farmMode || false;
        gameState.unlockedFloors = loaded.unlockedFloors || [1];
        gameState.unlockedWorlds = loaded.unlockedWorlds || [1];
        gameState.autoCollect = loaded.autoCollect !== undefined ? loaded.autoCollect : true;
        gameState.autoUpgrade = loaded.autoUpgrade || false;
        gameState.autoPrestige = loaded.autoPrestige || false;
        gameState.inventory = loaded.inventory || {};
        gameState.equippedArtifacts = loaded.equippedArtifacts || [];
        gameState.ownedArtifacts = loaded.ownedArtifacts || [];
        gameState.shopUpgrades = loaded.shopUpgrades || {};
        
        if (loaded.monsters) {
            Object.keys(loaded.monsters).forEach(key => {
                if (GAME_DATA.monsters[key]) {
                    GAME_DATA.monsters[key].lv = loaded.monsters[key];
                }
            });
        }
        
        if (loaded.heroes) {
            Object.keys(loaded.heroes).forEach(key => {
                if (GAME_DATA.heroes[key]) {
                    GAME_DATA.heroes[key].lv = loaded.heroes[key];
                }
            });
        }
        
        const now = Date.now();
        const offlineTime = Math.min((now - loaded.lastUpdate) / 1000, 43200);
        
        if (offlineTime > 60) {
            let offlineGold = 0;
            
            // Calculate offline passive income
            Object.keys(GAME_DATA.heroes).forEach(key => {
                const h = GAME_DATA.heroes[key];
                if (h.lv > 0) {
                    const heroPower = h.p * h.lv * (1 + (getArtifactBonus('hero_power') + getShopBonus('hero_power')) / 100);
                    offlineGold += heroPower * h.ar * 0.1 * offlineTime;
                }
            });
            
            offlineGold *= getMultiplier();
            
            gameState.gold += offlineGold;
            gameState.totalGoldEarned += offlineGold;
            
            showEventBanner('💤 OFFLINE', `+${formatNumber(offlineGold)} gold earned!`);
        }
        
        if (gameState.autoUpgrade) {
            document.getElementById('autoUpgradeToggle').classList.add('active');
        }
        if (gameState.autoPrestige) {
            document.getElementById('autoPrestigeToggle').classList.add('active');
        }
    }
    gameState.lastUpdate = Date.now();
}

init();

    </script>
