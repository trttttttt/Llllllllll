function selectRecipe(recipeKey) {
    gameState.selectedRecipe = recipeKey;
    
    document.querySelectorAll('.recipe-card').forEach(card => {
        card.classList.remove('selected');
    });
    
    const selectedCard = document.querySelector(`[data-recipe="${recipeKey}"]`);
    if (selectedCard) selectedCard.classList.add('selected');
    
    const recipe = GAME_DATA.recipes[recipeKey];
    const selectedDiv = document.getElementById('selectedRecipe');
    
    let matsHTML = '';
    let canCraft = true;
    
    Object.keys(recipe.m).forEach(matKey => {
        const needed = recipe.m[matKey];
        const owned = gameState.inventory[matKey] || 0;
        const hasEnough = owned >= needed;
        
        if (!hasEnough) canCraft = false;
        
        matsHTML += `
            <div style="color: ${hasEnough ? '#38ef7d' : '#ff6b6b'}; margin: 5px 0;">
                ${GAME_DATA.items[matKey].e} ${GAME_DATA.items[matKey].n}: ${owned}/${needed}
            </div>
        `;
    });
    
    selectedDiv.innerHTML = `
        <div style="font-size: 48px; margin-bottom: 15px;">${recipe.e}</div>
        <h3>${recipe.n}</h3>
        <div style="margin: 15px 0; padding: 10px; background: rgba(255,255,255,0.1); border-radius: 8px;">
            <strong>Bonus:</strong> ${getBonusDescription(recipe.b)}
        </div>
        <div style="margin-top: 15px;">
            <strong>Materials:</strong>
            ${matsHTML}
        </div>
    `;
    
    document.getElementById('craftBtn').disabled = !canCraft;
}

function getBonusDescription(bonus) {
    const types = {
        'hero_power': `+${bonus.v}% Hero Power`,
        'hero_defense': `+${bonus.v}% Hero Defense`,
        'gold_bonus': `+${bonus.v}% Gold Drop`,
        'drop_rate': `+${bonus.v}% Item Drop Rate`,
        'spawn_rate': `+${bonus.v}% Spawn Rate`,
        'all_bonus': `+${bonus.v}% All Stats`
    };
    return types[bonus.t] || 'Unknown Bonus';
}

function craftItem() {
    if (!gameState.selectedRecipe) return;
    
    const recipe = GAME_DATA.recipes[gameState.selectedRecipe];
    
    let canCraft = true;
    Object.keys(recipe.m).forEach(matKey => {
        const needed = recipe.m[matKey];
        const owned = gameState.inventory[matKey] || 0;
        if (owned < needed) canCraft = false;
    });
    
    if (!canCraft) {
        showAchievement('❌ Not enough materials!');
        return;
    }
    
    Object.keys(recipe.m).forEach(matKey => {
        gameState.inventory[matKey] -= recipe.m[matKey];
    });
    
    if (!gameState.ownedArtifacts.includes(gameState.selectedRecipe)) {
        gameState.ownedArtifacts.push(gameState.selectedRecipe);
    }
    
    showAchievement(`✨ Crafted ${recipe.n}!`);
    
    renderInventory();
    renderCraftingRecipes();
    renderArtifacts();
    selectRecipe(gameState.selectedRecipe);
}

