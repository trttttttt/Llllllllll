    ];
}

function spawnMonsters(deltaTime) {
    if (gameState.farmMode) return;
    
    const multiplier = getMultiplier();
    const spawnBonus = 1 + (getShopBonus('spawn_rate') / 100);
    
    Object.keys(GAME_DATA.monsters).forEach(key => {
        const m = GAME_DATA.monsters[key];
        if (m.lv > 0) {
            const spawnChance = m.sr * m.lv * deltaTime * spawnBonus;
            if (Math.random() < spawnChance / 10) {
                gameState.activeMonsters.push({
                    type: key,
                    hp: 100 * (1 + gameState.currentFloor * 0.5),
                    maxHp: 100 * (1 + gameState.currentFloor * 0.5),
                    emoji: m.e,
                    dropRate: m.dr * multiplier
                });
            }
        }
    });

    Object.keys(GAME_DATA.heroes).forEach(key => {
        const h = GAME_DATA.heroes[key];
        if (h.lv > 0) {
            const spawnChance = 0.5 * h.lv * deltaTime;
            if (Math.random() < spawnChance / 10) {
                gameState.activeHeroes.push({
                    type: key,
                    power: h.p * h.lv * (1 + (getArtifactBonus('hero_power') + getShopBonus('hero_power')) / 100),
                    emoji: h.e,
                    attackRate: h.ar
                });
            }
        }
    });

    if (gameState.activeMonsters.length > 50) gameState.activeMonsters = gameState.activeMonsters.slice(-50);
    if (gameState.activeHeroes.length > 30) gameState.activeHeroes = gameState.activeHeroes.slice(-30);
}

function heroesAttack(deltaTime) {
    gameState.activeHeroes.forEach(hero => {
        if (Math.random() < hero.attackRate * deltaTime) {
            if (gameState.bossActive) {
                const bossDamage = hero.power * (1 + getShopBonus('boss_damage') / 100);
                gameState.bossHP -= bossDamage;
                if (gameState.bossHP <= 0) defeatBoss();
            } else if (gameState.activeMonsters.length > 0) {
                const idx = Math.floor(Math.random() * gameState.activeMonsters.length);
                const monster = gameState.activeMonsters[idx];
                monster.hp -= hero.power;
                if (monster.hp <= 0) killMonster(monster, idx);
            }
        }
    });
}

function killMonster(monster, index) {
    const goldDrop = monster.dropRate * (1 + gameState.currentFloor * 0.2) * (1 + (getArtifactBonus('gold_bonus') + getShopBonus('gold_bonus')) / 100);
    gameState.gold += goldDrop;
    gameState.totalGoldEarned += goldDrop;
    gameState.monstersKilled++;
    
    if (!gameState.farmMode) gameState.floorProgress += 1;
    
    dropItems();
    if (gameState.autoCollect) createLootParticle();
    
    gameState.activeMonsters.splice(index, 1);
    if (!gameState.farmMode) checkFloorProgress();
}

function dropItems() {
    const dropBonus = 1 + ((getArtifactBonus('drop_rate') + getShopBonus('drop_rate')) / 100);
    
    Object.keys(GAME_DATA.items).forEach(itemKey => {
        const item = GAME_DATA.items[itemKey];
        const adjustedChance = item.d * dropBonus * (1 + gameState.currentFloor * 0.01);
        
        if (Math.random() < adjustedChance) {
            if (!gameState.inventory[itemKey]) gameState.inventory[itemKey] = 0;
            gameState.inventory[itemKey]++;
        }
    });
}

function defeatBoss() {
    gameState.bossActive = false;
    
    const bossGold = gameState.currentFloor * 1000 * getMultiplier();
    gameState.gold += bossGold;
    gameState.totalGoldEarned += bossGold;
    
    const rareMats = ['dragon_scale', 'phoenix_feather', 'void_crystal', 'celestial_ore', 'demon_horn', 'angel_wing', 'time_shard', 'cosmic_dust'];
    rareMats.forEach(material => {
        if (Math.random() < 0.4) {
            if (!gameState.inventory[material]) gameState.inventory[material] = 0;
            gameState.inventory[material] += Math.floor(1 + gameState.currentFloor / 15);
        }
    });
    
    showEventBanner('🎉 BOSS DEFEATED!', `+${formatNumber(bossGold)} Gold!`);
    
    // Check if finished floor 100, 200, 300, etc (world completion)
    if (gameState.currentFloor % 100 === 0 && !gameState.farmMode) {
        const nextWorld = Math.floor(gameState.currentFloor / 100) + 1;
        if (nextWorld <= 10 && !gameState.unlockedWorlds.includes(nextWorld)) {
            gameState.unlockedWorlds.push(nextWorld);
            gameState.unlockedWorlds.sort((a, b) => a - b);
            showEventBanner('🌍 NEW WORLD UNLOCKED!', WORLDS[nextWorld - 1].name);
            renderWorldSelector();
        }
    }
    
    if (!gameState.farmMode && gameState.currentFloor < 1000) {
        gameState.currentFloor++;
        gameState.floorProgress = 0;
        
        if (!gameState.unlockedFloors.includes(gameState.currentFloor)) {
            gameState.unlockedFloors.push(gameState.currentFloor);
            gameState.unlockedFloors.sort((a, b) => a - b);
        }
        
        renderFloorGrid();
        showAchievement(`🏰 Floor ${gameState.currentFloor} Unlocked!`);
    }
}

function checkFloorProgress() {
    if (isBossFloor(gameState.currentFloor)) return;
    
    const requiredKills = getRequiredKills();
    if (gameState.floorProgress >= requiredKills) {
        if (gameState.currentFloor < 1000) {
            gameState.currentFloor++;
            gameState.floorProgress = 0;
            
            if (!gameState.unlockedFloors.includes(gameState.currentFloor)) {
                gameState.unlockedFloors.push(gameState.currentFloor);
                gameState.unlockedFloors.sort((a, b) => a - b);
            }
            
            renderFloorGrid();
            showAchievement(`🏰 Floor ${gameState.currentFloor} Unlocked!`);
        }
    }
}

function getRequiredKills() {
    const baseKills = isBossFloor(gameState.currentFloor) ? 100 + (gameState.currentFloor * 5) : 50 + (gameState.currentFloor * 10);
    const reduction = 1 - (getShopBonus('floor_speed') / 100);
    return Math.floor(baseKills * reduction);
}

function toggleFarmMode() {
    gameState.farmMode = !gameState.farmMode;
    const btn = document.getElementById('farmModeBtn');
    
    if (gameState.farmMode) {
        btn.textContent = '🌾 Farm Mode: ON';
        btn.classList.add('active');
        showAchievement('🌾 Farm Mode ON!');
    } else {
        btn.textContent = '🌾 Farm Mode: OFF';
        btn.classList.remove('active');
        showAchievement('🌾 Farm Mode OFF!');
    }
}

function selectFloor(floor) {
    if (!gameState.unlockedFloors.includes(floor)) {
        showAchievement('🔒 Floor locked!');
        return;
    }
    
    gameState.currentFloor = floor;
    gameState.currentWorld = Math.ceil(floor / 100);
    gameState.floorProgress = 0;
    gameState.bossActive = false;
    gameState.activeMonsters = [];
    
    renderFloorGrid();
    renderWorldSelector();
    showAchievement(`🏰 Teleported to Floor ${floor}!`);
}

function selectWorld(worldId) {
    if (!gameState.unlockedWorlds.includes(worldId)) {
        showAchievement('🔒 Complete previous world first!');
        return;
    }
    
    gameState.currentWorld = worldId;
    const startFloor = (worldId - 1) * 100 + 1;
    
    // Find first unlocked floor in this world
    let targetFloor = startFloor;
    for (let i = startFloor; i <= worldId * 100; i++) {
        if (gameState.unlockedFloors.includes(i)) {
            targetFloor = i;
            break;
        }
    }
    
    gameState.currentFloor = targetFloor;
    gameState.floorProgress = 0;
    gameState.bossActive = false;
    gameState.activeMonsters = [];
    
    renderFloorGrid();
    renderWorldSelector();
    showAchievement(`🌍 Entered ${WORLDS[worldId - 1].name}!`);
}

function renderWorldSelector() {
    // Create world selector if it doesn't exist
    let worldSelector = document.getElementById('worldSelector');
    if (!worldSelector) {
        worldSelector = document.createElement('div');
        worldSelector.id = 'worldSelector';
        worldSelector.style.cssText = `
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 10px;
            margin-bottom: 20px;
            background: rgba(0,0,0,0.4);
            padding: 15px;
            border-radius: 15px;
        `;
        
        const floorsSection = document.getElementById('floors');
        floorsSection.insertBefore(worldSelector, floorsSection.firstChild);
    }
    
    worldSelector.innerHTML = '<h3 style="grid-column: 1/-1; margin-bottom: 10px;">🌍 World Selection</h3>';
    
    WORLDS.forEach(world => {
        const isUnlocked = gameState.unlockedWorlds.includes(world.id);
        const isCurrent = gameState.currentWorld === world.id;
        
        const worldBox = document.createElement('div');
        worldBox.style.cssText = `
            background: ${isUnlocked ? world.color : '#333'};
            padding: 15px;
            border-radius: 10px;
            text-align: center;
            cursor: ${isUnlocked ? 'pointer' : 'not-allowed'};
            opacity: ${isUnlocked ? 1 : 0.5};
            border: 3px solid ${isCurrent ? '#ffd700' : 'transparent'};
            transition: all 0.3s;
        `;
        
        if (isUnlocked) {
            worldBox.onmouseover = function() {
                this.style.transform = 'translateY(-5px)';
                this.style.boxShadow = '0 10px 30px rgba(255, 215, 0, 0.5)';
            };
            worldBox.onmouseout = function() {
                this.style.transform = 'translateY(0)';
                this.style.boxShadow = 'none';
            };
            worldBox.onclick = () => selectWorld(world.id);
        }
        
        worldBox.innerHTML = `
            <div style="font-size: 24px; font-weight: bold;">World ${world.id}</div>
            <div style="font-size: 12px; margin-top: 5px;">${world.name}</div>
            <div style="font-size: 10px; margin-top: 5px; opacity: 0.8;">Floors ${world.floors[0]}-${world.floors[1]}</div>
            ${!isUnlocked ? '<div style="font-size: 18px; margin-top: 5px;">🔒</div>' : ''}
        `;
        
        worldSelector.appendChild(worldBox);
    });
}

function renderFloorGrid() {
    const container = document.getElementById('floorGrid');
    container.innerHTML = '';
    
    // Show floors for current world only
    const startFloor = (gameState.currentWorld - 1) * 100 + 1;
    const endFloor = gameState.currentWorld * 100;
    
    for (let i = startFloor; i <= endFloor; i++) {
        const box = document.createElement('div');
        box.className = 'floor-box';
        
        if (!gameState.unlockedFloors.includes(i)) box.classList.add('locked');
        if (i === gameState.currentFloor) box.classList.add('current');
        if (isBossFloor(i)) box.classList.add('boss-floor');
        
        box.innerHTML = `
            <div style="font-size: 20px; font-weight: bold;">Floor ${i}</div>
            ${isBossFloor(i) ? '<div style="color: #ff4444; font-size: 11px;">BOSS</div>' : ''}
        `;
        
        box.onclick = () => selectFloor(i);
        container.appendChild(box);
    }
}

function renderInventory() {
    const container = document.getElementById('inventoryGrid');
    container.innerHTML = '';
    
    const hasItems = Object.keys(gameState.inventory).length > 0;
    
    if (!hasItems) {
        container.innerHTML = '<div style="grid-column: 1/-1; text-align: center; padding: 40px; opacity: 0.7;">No items yet!</div>';
